{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"name": "ntun/cli",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/cmd/cli/ntun.go",
			"env": {
				"CGO_ENABLED": "1",
				"LOG_LEVEL": "debug",
				"DEVELOPMENT": "true"
			}
		},
		{
			"name": "ntun/dev",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/cmd/dev/ntun.go",
			"env": {
				"CGO_ENABLED": "1",
				"LOG_LEVEL": "debug",
				"DEVELOPMENT": "true"
			}
		}
	]
}